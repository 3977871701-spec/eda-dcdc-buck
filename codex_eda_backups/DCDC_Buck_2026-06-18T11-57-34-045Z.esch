["FONTSTYLE","st14",null,null,null,25,0,0,0,0,2,0]
["TEXT","e76",80,662,0,"1. Keep CIN, U1 switching pin, D1 and power ground loop short.","st14"]
["TEXT","e77",80,696,0,"2. Select L1 saturation current above peak switch current.","st14"]
["TEXT","e78",80,730,0,"3. CIN/COUT voltage rating, ripple current and ESR must match real load.","st14"]
["TEXT","e79",80,764,0,"4. Replace U1 with a real buck IC symbol before PCB/BOM release.","st14"]
["TEXT","e80",80,70,0,"DCDC Buck Converter - real JLC EDA devices + footprints","st5"]
